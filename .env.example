# Copy this file to ".env" for LOCAL testing and fill in your values.
# (On GitHub these go into repo Settings -> Secrets and variables -> Actions.)
#
# Load it locally with:  python -c "import dotenv" ... or just set them in your
# shell. The .env file is git-ignored and never uploaded.

# --- E-mail (Gmail) ---------------------------------------------------------
# SMTP_USER = your full Gmail address
# SMTP_PASS = a Google "App password" (16 chars, create at
#             https://myaccount.google.com/apppasswords ). NOT your login password.
# EMAIL_TO  = where alerts go (defaults to SMTP_USER if omitted)
SMTP_USER=your.address@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
EMAIL_TO=your.address@gmail.com

# --- ntfy push (desktop + phone popups) -------------------------------------
# Pick any hard-to-guess topic name, then subscribe to it in the ntfy app /
# https://ntfy.sh/<your-topic>. Anyone who knows the topic can read it, so make
# it unguessable.
NTFY_TOPIC=klima-monitor-9f3k2x7q
# NTFY_SERVER=https://ntfy.sh
